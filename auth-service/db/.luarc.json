{
  "$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/master/setting/schema.json",
  "runtime": {
    "version": "Lua 5.4"
  },
  "workspace": {
    "library": [
      ".luacats"
    ],
    "checkThirdParty": false
  },
  "diagnostics": {
    "globals": [
      "pg",
      "mysql",
      "sqlite",
      "EnumBuilder",
      "TableBuilder",
      "ColumnBuilder",
      "IndexBuilder",
      "ReferenceAction",
      "IndexMethod"
    ]
  }
}
